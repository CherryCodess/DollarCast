# Core app
DATABASE_URL=postgresql://dollarcast:dollarcast@postgres:5432/dollarcast?schema=public
# Optional Python/psycopg URL for managed Postgres. If omitted in Docker Compose, WEATHER_DATABASE_URL falls back to the local postgres service.
WEATHER_DATABASE_URL=postgresql+psycopg://dollarcast:dollarcast@postgres:5432/dollarcast
REDIS_URL=redis://redis:6379
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Kalshi public market-data API. No private keys are used by this MVP.
KALSHI_API_BASE=https://external-api.kalshi.com/trade-api/v2
KALSHI_DOCS_URL=https://docs.kalshi.com

# Weather APIs and source buckets
NWS_API_BASE=https://api.weather.gov
AVIATION_WEATHER_API_BASE=https://aviationweather.gov/api/data
NOAA_NBM_SOURCE_BASE=https://noaa-nbm-grib2-pds.s3.amazonaws.com
NOAA_HRRR_SOURCE_BASE=https://noaa-hrrr-bdp-pds.s3.amazonaws.com
WEATHER_SERVICE_URL=http://weather-service:8000

# Refresh cadence
MARKET_REFRESH_SECONDS=30
OBSERVATION_REFRESH_SECONDS=300
FORECAST_REFRESH_SECONDS=900
EDGE_SCANNER_INTERVAL_SECONDS=120
WEATHER_INGESTION_INTERVAL_SECONDS=900
FORECAST_CACHE_MAX_AGE_SECONDS=5400
REQUIRE_FRESH_NWS=true
REQUIRE_GRIB_WHEN_ENABLED=true
STALE_FORECAST_FACTOR=2
STALE_OBSERVATION_FACTOR=3

# Recommendation defaults
DEFAULT_UNCERTAINTY_BUFFER=0.03
DEFAULT_MIN_NET_EDGE=0.05
DEFAULT_MAX_SINGLE_MARKET_PCT=0.03
DEFAULT_MAX_CITY_DAY_PCT=0.06
DEFAULT_MAX_TOTAL_DEPLOYMENT_PCT=0.75

# Live market scan bounds. Increase cautiously to avoid public API rate limits.
KALSHI_MARKET_PAGE_LIMIT=200
KALSHI_MARKET_MAX_PAGES=2
KALSHI_CACHE_SECONDS=120
KALSHI_MAX_RETRIES=4
KALSHI_RETRY_BASE_MS=750
KALSHI_RETRY_MAX_MS=8000
KALSHI_CIRCUIT_BREAKER_FAILURES=4
KALSHI_CIRCUIT_BREAKER_COOLDOWN_MS=120000
KALSHI_SERIES_CACHE_SECONDS=3600
PROBABILITY_CACHE_SECONDS=900
EDGE_DISTRIBUTION_SAMPLES=25000
EDGE_RESPONSE_SIMULATION_SAMPLES=1000
EDGE_SCAN_CONCURRENCY=16
KALSHI_SERIES_CONCURRENCY=24
KALSHI_FETCH_EVENT_TITLES=false
KALSHI_DYNAMIC_SERIES_DISCOVERY=false
EXCLUDE_DECIDED_PRICE=0.98
EDGE_SCAN_ALL_MARKETS=false
ALLOCATION_LIQUIDITY_CHECK_CONTRACTS=1000
MAX_EDGE_CHECKS=48
EDGE_PRESELECT_MULTIPLIER=5
MAX_EDGE_CHECKS_PER_EVENT=8
MAX_EDGE_SCAN_GROUPS=8
KALSHI_DAILY_TEMPERATURE_SERIES=HIGHNY,HIGHCHI,HIGHAUS,HIGHMIA,KXHIGHNY,KXHIGHNYD,KXHIGHCHI,KXHIGHAUS,KXHIGHMIA,KXHIGHLAX,KXHIGHDEN,KXDENHIGH,KXHIGHHOU,KXHIGHOU,KXHIGHTATL,KXHIGHTBOS,KXHIGHTDAL,KXHIGHTDC,KXHIGHTHOU,KXHIGHTLV,KXHIGHTMIN,KXHIGHTNOLA,KXHIGHTOKC,KXHIGHPHIL,KXPHILHIGH,KXHIGHTPHX,KXHIGHTSATX,KXHIGHTSEA,KXHIGHTSFO,KXHOUHIGH,KXLOWTNYC,KXLOWTCHI,KXLOWTMIA,KXLOWTAUS,KXLOWTLAX,KXLOWTDEN,KXLOWNYC,KXLOWNY,KXLOWCHI,KXLOWMIA,KXLOWAUS,KXLOWDEN,KXLOWLAX,KXLOWPHIL,KXLOWTATL,KXLOWTBOS,KXLOWTDAL,KXLOWTDC,KXLOWTHOU,KXLOWTLV,KXLOWTMIN,KXLOWTNOLA,KXLOWTOKC,KXLOWTPHIL,KXLOWTPHX,KXLOWTSATX,KXLOWTSEA,KXLOWTSFO,KXMINNYC,MINNYC
KALSHI_HOURLY_TEMPERATURE_SERIES=KXTEMPNYCH,KXTEMPCHIH,KXTEMPLAXH,KXTEMPMIAH,KXTEMPDCH,KXTEMPBOSH

# Demo fallback. Live mode is attempted first; fixture/demo responses are clearly labeled.
NEXT_PUBLIC_DEMO_MODE=false
DEMO_MODE=false

# Probability engine defaults
SIGMA_DAILY_F=1.4
SIGMA_HOURLY_F=0.9
AR1_RHO=0.80
MONTE_CARLO_PATHS=25000
ENABLE_GRIB_INGESTION=true
GRIB_CACHE_DIR=/tmp/dollarcast-grib
GRIB_RUN_LOOKBACK_HOURS=18
NBM_MAX_FORECAST_HOUR=36
HRRR_MAX_FORECAST_HOUR=18
WEATHER_WORKER_STATION_LIMIT=40

# Retention and storage control. These prevent local Docker/Postgres/cache growth from being unbounded.
RETENTION_CLEANUP_ENABLED=true
RETENTION_DRY_RUN=false
RETENTION_WORKER_INTERVAL_SECONDS=3600
EDGE_SNAPSHOT_RETENTION_DAYS=7
PROBABILITY_SNAPSHOT_RETENTION_DAYS=7
ORDERBOOK_SNAPSHOT_RETENTION_DAYS=2
FORECAST_RUN_RETENTION_DAYS=3
OBSERVATION_RETENTION_DAYS=7
REFRESH_LOG_RETENTION_DAYS=14
ALLOCATION_RUN_RETENTION_DAYS=30
GRIB_CACHE_RETENTION_HOURS=24
